{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "cSpell.useGitignore": true,
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "bumpp",
    "changelogithub",
    "demi",
    "destructurable",
    "echarts",
    "esbuild",
    "iconify",
    "INTLIFY",
    "nocheck",
    "ntnyq",
    "oxfmt",
    "oxlint",
    "pathe",
    "pinia",
    "tsbuildinfo",
    "unocss",
    "unplugin",
    "unref",
    "unrs",
    "valibot",
    "vite",
    "vueuse",
    "xgplayer"
  ]
}
